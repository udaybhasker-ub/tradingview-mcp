# =============================================================
# tradingview-mcp — Local Environment Configuration
# =============================================================
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your values below
# 3. .env is in .gitignore — it will NEVER be committed to git
# =============================================================

# ── Proxy (Optional — Webshare Rotating Residential) ──────────
# Get credentials from: https://proxy.webshare.io/proxy/list
# Enables access to Yahoo Finance, Xueqiu, and reduces Reddit rate-limits.
# Leave blank to run WITHOUT proxy (Reddit & RSS will still work).

PROXY_HOST=p.webshare.io
PROXY_PORT=80
PROXY_USERNAME_PREFIX=your_username_prefix   # e.g. hvfvdamo
PROXY_PASSWORD=your_password_here
PROXY_SESSION_MIN=1
PROXY_SESSION_MAX=250

# Set to false to disable proxy entirely
PROXY_ENABLED=true

# ── Remote OAuth (Optional — required for Claude.ai custom connectors / Postman MCP) ──
# Leave both unset to run unauthenticated (e.g. local development).
# MCP_AUTH_TOKEN: a long random shared secret. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# MCP_PUBLIC_URL: the public https URL of this deployment, no trailing slash
#   (e.g. https://your-app.up.railway.app)
# With both set, /authorize will show a login form that asks for MCP_AUTH_TOKEN.

MCP_AUTH_TOKEN=
MCP_PUBLIC_URL=
